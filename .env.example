# --- Already typical on Vercel (VITE_* is available to the serverless API too) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Resend (API key you have; add FROM) ---
RESEND_API_KEY=
# Required for sending: verified domain in Resend, e.g. Auzaar <hello@mail.yourdomain.com>
RESEND_FROM=
# RESEND_REPLY_TO=

# --- Email HTML logo (absolute https URL for <img>; optional) ---
# Vercel sets VERCEL_URL; we use https://VERCEL_URL/brand/auzaar-logo.svg automatically.
# For production custom domain or a PNG (better in Outlook), set one of:
# PUBLIC_SITE_URL=https://www.yourdomain.com
# EMAIL_LOGO_URL=https://www.yourdomain.com/brand/auzaar-logo.png

# --- Optional upgrade (recommended later) ---
# Same project URL; duplicate of VITE_ is fine if you prefer a server-only name
# SUPABASE_URL=
# Service role bypasses RLS; then you can revoke anon INSERT on demo_requests
# SUPABASE_SERVICE_ROLE_KEY=

# --- Browser only (optional) ---
# VITE_PUBLIC_API_ORIGIN=https://your-preview.vercel.app
